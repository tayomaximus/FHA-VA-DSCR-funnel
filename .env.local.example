# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Lead Delivery ─────────────────────────────────────────────
# Webhook URL to forward all lead submissions (GHL, Zapier, Make, n8n, etc.)
LEAD_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_HOOK_ID/webhook-trigger/YOUR_TRIGGER_ID

# ── Google Analytics / Google Tag Manager ─────────────────────
# GA4 Measurement ID (used in layout.tsx gtag script)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Ads Conversion Tracking (per funnel) ───────────────
# AW-XXXXXXXXXX is your Google Ads account conversion ID
NEXT_PUBLIC_GADS_CONVERSION_ID_FHA=AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_LABEL_FHA=XXXXXXXXXXXX

NEXT_PUBLIC_GADS_CONVERSION_ID_VA=AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_LABEL_VA=XXXXXXXXXXXX

NEXT_PUBLIC_GADS_CONVERSION_ID_DSCR=AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_LABEL_DSCR=XXXXXXXXXXXX
